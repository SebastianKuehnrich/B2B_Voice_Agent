# ─────────────────────────────────────────────────────────────────
# B2B Voice Agent – TalentFlow | Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
WEBHOOK_SECRET=your_webhook_secret_here       # Random 32-char string for HMAC verification
WEBHOOK_URL=https://your-ngrok-url.ngrok-free.dev  # ngrok URL, update after: ngrok http 3001

# ── Vapi ──────────────────────────────────────────────────────────
# Dashboard: https://dashboard.vapi.ai > API Keys
VAPI_API_KEY=your_vapi_private_key_here       # Private Key (nicht Public Key!)
# Nach create-assistant.js ausfuehren:
VAPI_ASSISTANT_ID=your_assistant_id_here      # Wird von scripts/create-assistant.js ausgegeben
VAPI_PHONE_NUMBER_ID=your_phone_number_id     # Vapi Dashboard > Phone Numbers (optional)
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret  # Beliebiger geheimer String fuer HMAC

# ── Anthropic / Claude ────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── ElevenLabs (TTS – Stimme fuer Lisa) ──────────────────────────
# https://elevenlabs.io > Entwickler > API Keys
# Berechtigungen: nur "Text zu Sprache" benoetigt
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Voice ID: ElevenLabs > Stimmen > Lisa > Voice ID kopieren
ELEVENLABS_VOICE_ID=your_voice_id_here

# ── Deepgram (STT – Spracherkennung Deutsch) ──────────────────────
# https://deepgram.com > Console > API Keys
# 200 USD Free Credit bei Registrierung
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Cal.com (Kalender-Buchungen) ──────────────────────────────────
# https://cal.com/settings/developer/api-keys
CALCOM_API_KEY=your_calcom_api_key
CALCOM_API_URL=https://api.cal.com/v2
# Event Type ID: app.cal.com/event-types/XXXXXXX/edit (Zahl aus URL)
CALCOM_EVENT_TYPE_ID=your_event_type_id
# Username: sichtbar in cal.com URL (z.B. sebastian-kuhnrich-9s024i)
CALCOM_USERNAME=your_calcom_username
# Timezone: Standard Europe/Berlin, aenderbar auf beliebige IANA Timezone
CALCOM_TIMEZONE=Europe/Berlin

# ── Supabase ──────────────────────────────────────────────────────
# https://supabase.com > Projekt > Einstellungen > API
SUPABASE_URL=https://your-project.supabase.co
# "Verlegbarer Schluessel" (sb_publishable_...)
SUPABASE_ANON_KEY=your_supabase_anon_key
# "Geheimschluessel" (sb_secret_...) – nur server-seitig verwenden!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Dashboard (Next.js) ───────────────────────────────────────────
# Gleiche Werte wie oben – NEXT_PUBLIC_ Prefix fuer Client-side Zugriff
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── OpenAI (Embeddings) ───────────────────────────────────────────
# https://platform.openai.com/api-keys
# Wird fuer text-embedding-3-small (Vektorsuche) benoetigt
OPENAI_API_KEY=your_openai_api_key

# ── Langfuse (LLM Observability) ──────────────────────────────────
# https://cloud.langfuse.com > Organisation > Projekt > Settings > API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── HuggingFace (Fine-Tuning) ─────────────────────────────────────
# Nur fuer SFT-Modus benoetigt (LeoLM ist ein gated Modell).
# Classifier-Modus (bert-base-german-cased) funktioniert OHNE Token.
# Token erstellen: https://huggingface.co/settings/tokens (Read reicht)
# Modell-Zugriff: https://huggingface.co/LeoLM/leo-hessianai-3b
HUGGINGFACE_TOKEN=hf_your_token_here

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=debug    # debug | info | warn | error
